{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Sports Predictor",
      "type": "shell",
      "command": "git pull --ff-only 2>/dev/null || true && streamlit run main.py --server.port 8501 --server.address 0.0.0.0 --server.headless true",
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Starting.*$",
          "endsPattern": "^.*You can now view.*$"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "startup"
      }
    }
  ]
}
