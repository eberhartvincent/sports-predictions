# Sports Predictor — daily cache warm at 12:00 PM Eastern
# Cron uses local system time (TZ=America/New_York set in Dockerfile)
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin
PYTHONPATH=/app

0 12 * * * cd /app && python warm_cache.py >> /var/log/warm_cache.log 2>&1

# Empty line required by cron
